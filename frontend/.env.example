MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/note-taking-app
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
APP_URL=http://localhost:3000

# Dev only — Vite proxies /api/* to this backend
BACKEND_URL=http://localhost:3001

# Vercel production (set in Vercel dashboard → Settings → Environment Variables)
# MONGODB_URI=...
# JWT_SECRET=... (min 32 characters)
# APP_URL=https://your-app.vercel.app
# Do NOT set BACKEND_URL in production
